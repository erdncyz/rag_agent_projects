APP_NAME=Single Document RAG UI
APP_ENV=dev
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=embeddinggemma
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=single_doc_rag
TOP_K=6
CHUNK_SIZE=1100
CHUNK_OVERLAP=180
MAX_CONTEXT_CHUNKS=5
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_LEXICAL_WEIGHT=0.3
RERANK_ENABLED=true
ABSTAIN_IF_NO_STRONG_CONTEXT=true
MAX_ACCEPTABLE_DISTANCE=1.2
MIN_CONTEXT_RESULTS=1
ADMIN_API_KEY = 
AGENT_ENABLE_TRACE=true
AGENT_MAX_STEPS=4
AGENT_DEFAULT_MODE=agent
AGENT_MAX_SOURCES_TO_PROBE=3
AGENT_PER_SOURCE_TOP_K=2